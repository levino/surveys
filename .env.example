# Copy to .env and fill in. See README.md for details.

PORT=8080
DATABASE_PATH=./data/app.db
PUBLIC_BASE_URL=http://localhost:8080
PUBLIC_APP_NAME=Surveys
PUBLIC_THEME=surveys

# Upstream OIDC identity provider (Zitadel, Keycloak, dex, …).
# Must emit the user's group/team membership as the `groups` claim.
OIDC_ISSUER=
OIDC_CLIENT_ID=surveys
OIDC_CLIENT_SECRET=
# Optional: strip a namespace prefix from group strings (e.g. "myorg:").
OIDC_GROUP_PREFIX=

# Random secret used to salt IP hashes (set to a long random string).
SESSION_SECRET=
